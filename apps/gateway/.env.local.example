PORT=3002

# Supabase — for uploading WhatsApp media to Storage temp folder
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=

# Supabase — transaction pooler URL (same as apps/web)
# Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Twilio credentials
# https://console.twilio.com → Account Info (top left)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=

# Full public URL of this service — needed for Twilio signature verification
# Local dev: run "ngrok http 3002", paste the https URL here + /webhooks/twilio
# Leave empty to skip signature verification in local dev
TWILIO_WEBHOOK_URL=https://<your-ngrok-subdomain>.ngrok-free.app/webhooks/twilio

# Shared secret between gateway ↔ agent ↔ web — any long random string, same in all three
# Generate: openssl rand -hex 32
GATEWAY_SECRET=

# Base URL of apps/agent
AGENT_API_BASE=http://localhost:3001
