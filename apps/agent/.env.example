PORT=3001

# Supabase — transaction pooler URL
# Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase API (for auth token validation)
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=

# Google AI
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Secret for inbound calls from Gateway → Agent
# Must match apps/gateway GATEWAY_SECRET
# Generate: openssl rand -hex 32
GATEWAY_SECRET=

# Secret for outbound calls from Agent → Web-API
# Must match apps/web AGENT_SECRET
# Generate: openssl rand -hex 32
AGENT_SECRET=

# Base URL of apps/web — for AI tools to call the PM API
WEB_API_BASE=http://localhost:3000
